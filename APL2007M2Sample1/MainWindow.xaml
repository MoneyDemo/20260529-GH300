<ui:FluentWindow x:Class="ParallelAsyncExample.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Parallel Async Downloader"
                 Width="920"
                 Height="620"
                 MinWidth="760"
                 MinHeight="520"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                 Background="{DynamicResource ApplicationBackgroundBrush}"
                 mc:Ignorable="d">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Title="Parallel Async Downloader"
                     Margin="0,0,0,12" />

        <ui:Card Grid.Row="1"
                 Margin="0,0,0,16"
                 Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ui:Button x:Name="_startButton"
                           Grid.RowSpan="2"
                           Padding="16,8"
                           Appearance="Primary"
                           Content="開始下載"
                           Icon="{ui:SymbolIcon Symbol=Play24}"
                           Click="OnStartButtonClick" />

                <ui:ProgressRing x:Name="_progressRing"
                                 Grid.Column="1"
                                 Grid.RowSpan="2"
                                 Width="24"
                                 Height="24"
                                 Margin="14,0,0,0"
                                 VerticalAlignment="Center"
                                 IsIndeterminate="True"
                                 Visibility="Collapsed" />

                <StackPanel Grid.Column="2"
                            Margin="18,0,24,0">
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="下載 Microsoft 文件頁面並即時顯示狀態" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Text="每列會顯示 URL、位元組大小，以及目前處理狀態。" />
                </StackPanel>

                <ui:ToggleSwitch x:Name="_themeToggleSwitch"
                                 Grid.Column="3"
                                 Grid.RowSpan="2"
                                 VerticalAlignment="Center"
                                 Checked="OnThemeToggleChanged"
                                 Unchecked="OnThemeToggleChanged" />

                <StackPanel Grid.Column="4"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center">
                    <TextBlock Text="主題" />
                    <TextBlock x:Name="_themeModeTextBlock"
                               Margin="0,4,0,0"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Text="淺色模式" />
                </StackPanel>
            </Grid>
        </ui:Card>

        <ui:Card Grid.Row="2"
                 Margin="0,0,0,16"
                 Padding="0">
            <DockPanel>
                <Border DockPanel.Dock="Top"
                        Padding="20,16,20,12"
                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                        BorderThickness="0,0,0,1">
                    <TextBlock FontSize="16"
                               FontWeight="SemiBold"
                               Text="下載結果" />
                </Border>

                <ListView x:Name="_resultsList"
                          ItemsSource="{Binding Results}"
                          BorderThickness="0"
                          Background="Transparent"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          Margin="8">
                    <ListView.View>
                        <GridView AllowsColumnReorder="False">
                            <GridViewColumn Width="560"
                                            Header="URL"
                                            DisplayMemberBinding="{Binding Url}" />
                            <GridViewColumn Width="120"
                                            Header="Size (bytes)"
                                            DisplayMemberBinding="{Binding BytesDisplay}" />
                            <GridViewColumn Width="140"
                                            Header="Status"
                                            DisplayMemberBinding="{Binding Status}" />
                        </GridView>
                    </ListView.View>
                </ListView>
            </DockPanel>
        </ui:Card>

        <ui:Card Grid.Row="3"
                 Padding="18,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="_summaryTextBlock"
                           VerticalAlignment="Center"
                           Text="準備就緒。" />

                <TextBlock Grid.Column="1"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Text="WPF UI 4.3.0" />
            </Grid>
        </ui:Card>
    </Grid>
</ui:FluentWindow>
